        edition = "2021";
        crateBin = [];
        sha256 = "0jaj5dyh3mks0805h4ldrsh5pwq4i2jc9dc9zwjm91k3gmwxhp7h";
        dependencies = [
          {
            name = "bumpalo";
            packageId = "bumpalo";
