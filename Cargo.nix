          "deflate-zlib-ng" = [ "flate2/zlib-ng" "deflate-flate2" ];
          "deflate-zopfli" = [ "zopfli" "_deflate-any" ];
          "deflate64" = [ "dep:deflate64" ];
          "flate2" = [ "dep:flate2" ];
          "getrandom" = [ "dep:getrandom" ];
          "hmac" = [ "dep:hmac" ];
          "lzma" = [ "lzma-rs/stream" ];
          "lzma-rs" = [ "dep:lzma-rs" ];
          "nt-time" = [ "dep:nt-time" ];
          "pbkdf2" = [ "dep:pbkdf2" ];
          "sha1" = [ "dep:sha1" ];
          "time" = [ "dep:time" ];
          "xz" = [ "dep:xz2" ];
          "zeroize" = [ "dep:zeroize" ];
          "zopfli" = [ "dep:zopfli" ];
