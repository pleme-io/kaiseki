          "nightly" = [ "crc32fast?/nightly" ];
          "std" = [ "crc32fast?/std" "dep:log" "simd-adler32?/std" ];
          "zlib" = [ "dep:simd-adler32" ];
        };
        resolvedDefaultFeatures = [ "default" "gzip" "std" "zlib" ];
      };
      "zstd" = rec {
        crateName = "zstd";
        version = "0.13.3";
